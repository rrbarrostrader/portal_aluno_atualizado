# Configurações do Banco de Dados (PostgreSQL)
# Para o DBeaver no Windows, geralmente o host é localhost
DATABASE_URL=postgres://postgres:sua_senha@localhost:5432/iab_fapegma

# Segredo para assinatura de cookies JWT (pode ser qualquer string longa e aleatória)
JWT_SECRET=iab_fapegma_portal_secret_key_2026

# Configurações de Ambiente
NODE_ENV=development
PORT=3000

# ID do Aplicativo (pode manter este valor)
VITE_APP_ID=iab-fapegma-portal
