# ============================================
# Configuração Local para Desenvolvimento
# ============================================

# Banco de Dados PostgreSQL
# Substitua os valores conforme sua configuração local
DATABASE_URL=postgres://postgres:postgres@localhost:5432/iab_fapegma

# Segredo JWT para assinatura de cookies
# Use uma string longa e aleatória em produção
JWT_SECRET=iab_fapegma_portal_secret_key_2026_local_dev

# Ambiente
NODE_ENV=development
PORT=3000

# ID do Aplicativo
VITE_APP_ID=iab-fapegma-portal

# Configurações de E-mail
# Opções: 'test' (padrão), 'gmail', 'outlook', 'mailtrap', 'smtp'
EMAIL_PROVIDER=test
EMAIL_FROM=noreply@iabfapgema.com.br
PORTAL_URL=http://localhost:3000

# Configuração para Gmail (se usar EMAIL_PROVIDER=gmail)
# GMAIL_USER=seu-email@gmail.com
# GMAIL_PASSWORD=sua-app-password

# Configuração para Outlook (se usar EMAIL_PROVIDER=outlook)
# OUTLOOK_USER=seu-email@outlook.com
# OUTLOOK_PASSWORD=sua-senha

# Configuração para Mailtrap (se usar EMAIL_PROVIDER=mailtrap)
# MAILTRAP_USER=seu-usuario-mailtrap
# MAILTRAP_PASSWORD=sua-senha-mailtrap

# Configuração para SMTP Genérico (se usar EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.seu-provedor.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu-usuario
# SMTP_PASSWORD=sua-senha

# Configurações opcionais (deixe em branco se não usar OAuth)
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
